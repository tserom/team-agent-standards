{
  "version": 1,
  "rules": [
    {
      "output": "karpathy-guidelines.mdc",
      "guideline": "karpathy.md",
      "description": "Behavioral guidelines to reduce common LLM coding mistakes. Use when writing, reviewing, or refactoring code.",
      "alwaysApply": true
    },
    {
      "output": "react-readability-conventions.mdc",
      "guideline": "react-readability.md",
      "description": "React/UI 与 *Api 可读性约定（少抽象、少 useEffect 业务链、入口注释）",
      "alwaysApply": false,
      "globs": ["src/**/*.tsx", "src/**/*Api.ts"]
    },
    {
      "output": "response-modified-files-summary.mdc",
      "guideline": "response-modified-files.md",
      "description": "改代码后在回复末尾用表格列出修改的文件及简要说明",
      "alwaysApply": true
    },
    {
      "output": "git-commit-message-continuity.mdc",
      "guideline": "git-commit-mr.md",
      "description": "连续提交时在 feat 文案末尾追加序号；合代码只推功能分支并建 MR/PR 草稿或给出链接，不直接 merge/push 到其它分支",
      "alwaysApply": true
    },
    {
      "output": "api-layering-decision.mdc",
      "guideline": "api-layering.md",
      "description": "前端 API 层 L0–L3；响应字段契约（禁止未声明业务字段 ?? 链）；实现 *Api.ts / services 前必读",
      "alwaysApply": true
    },
    {
      "output": "promote-to-team-standards.mdc",
      "guideline": "promote-to-team-standards.md",
      "description": "可复用规则/Skill 时提醒用户是否晋升到 team-agent-standards；说明 guidelines/docs/skills 分工",
      "alwaysApply": true
    },
    {
      "output": "receipt-batch-detail-tab.mdc",
      "guideline": "receipt-batch-detail-tab.md",
      "description": "详情页收货批次明细 Tab：STOCKBATCH_ENABLED、新列表接口、*ReceiptBatchRow 显式字段、回退登记表；勿照搬 other-in 字段链",
      "alwaysApply": false,
      "globs": ["src/**/*Api.ts", "src/**/services/**", "src/pages/**/detail*.tsx", "src/pages/**/create.tsx", "src/pages/**/*Section*.tsx", "src/pages/**/*Batch*.tsx"]
    }
  ]
}
